# Database (PostgreSQL - always)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cms_dev

# Payload
PAYLOAD_SECRET=REPLACE_ME_WITH_OPENSSL_RAND
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Storage (uncomment the one you need in production)
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# S3_ENDPOINT=
# BLOB_READ_WRITE_TOKEN=

# Email (uncomment the one you need)
# EMAIL_PROVIDER=console
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
